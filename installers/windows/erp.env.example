# Bambuddy ERP deploy secrets — OPTIONAL zero-touch ERP-login pre-config.
#
# Copy this file to `erp.env` (same directory), fill in real values, then
# rebuild the Windows installer with build.py / build-server-installer.sh.
# The build bundles erp.env and the installer lays it down at
#   C:\ProgramData\Bambuddy\config\erp.env
# which the app reads at runtime to pre-configure ERP directory login with no
# post-install steps. Omit the file and the build still succeeds — ERP login
# is simply not pre-configured (set it in Settings afterward).
#
# The real erp.env is gitignored (it carries erp_db_password) — NEVER commit
# it. Keys are lowercase and match the app's ERP settings fields exactly. One
# KEY=value per line; no surrounding quotes, no spaces around '='.

# Hostname or IP of the ERP MariaDB directory server.
erp_db_host=erp.example.internal

# ERP MariaDB port (MariaDB default is 3306).
erp_db_port=3306

# ERP identity database name (the one holding the users table).
erp_db_name=Foundi_management_system

# Read-only ERP DB account used for directory lookups.
erp_db_user=farm_reader

# Password for erp_db_user. Secret — this is why the real erp.env is gitignored.
erp_db_password=CHANGE_ME

# Connect to the ERP DB over TLS (true/false).
erp_db_ssl=false

# JSON object mapping ERP role -> Bambuddy group name.
erp_role_group_mapping={"ADMIN": "Administrators"}
